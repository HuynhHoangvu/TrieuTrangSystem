// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model VehicleType {
  id           String    @id @default(cuid())
  name         String    @unique
  pricePerTrip Int
  // "timed": lượt tự động chốt sau tripDurationMinutes (ATV/mô tô)
  // "manual": không giới hạn thời gian, chốt lượt khi quét lại đúng xe đó (ô tô/Land Cruiser)
  durationMode String    @default("timed")
  // "flat": dùng pricePerTrip cố định
  // "options": nhiều mức giá tuỳ chọn (khách vãng lai/khách quen/số người...),
  // tài xế chọn đúng mức khi quét xe, tra theo bảng priceOptions
  pricingMode  String    @default("flat")
  vehicles     Vehicle[]
  priceOptions PassengerPrice[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Một mức giá tuỳ chọn cho loại xe có pricingMode = "options".
// VD ATV: "Khách vãng lai" 800.000đ, "1 người (khách quen)" 400.000đ,
// "2 người (khách quen)" 600.000đ — không nhất thiết phải là số người.
model PassengerPrice {
  id         String      @id @default(cuid())
  typeId     String
  type       VehicleType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  // Tên hiển thị cho tài xế chọn, VD "Khách vãng lai", "1 người"
  label      String
  // Số người tương ứng (chỉ để ghi nhận/thống kê), để trống nếu không áp dụng
  passengers Int?
  price      Int
  // Có cho phép bấm "+X phút" cộng thêm giờ với mức giá này không
  // (VD: khách vãng lai cho cộng giờ, khách quen theo số người thì không)
  allowExtend Boolean    @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  trips Trip[]
}

model Vehicle {
  id            String      @id @default(cuid())
  code          String      @unique
  typeId        String
  type          VehicleType @relation(fields: [typeId], references: [id])
  priceOverride Int?
  status        String      @default("available")
  qrToken       String      @unique
  trips         Trip[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Driver {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  pinHash   String
  role      String   @default("driver")
  status    String   @default("active")
  trips     Trip[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  id                  String  @id @default("singleton")
  tripDurationMinutes Int     @default(20)
  allowEarlyRescan    Boolean @default(true)
  // Số phút cộng thêm mỗi lần bấm nút "+X phút" (giá cộng thêm tự tính tỉ lệ theo tripDurationMinutes)
  extendMinutes       Int     @default(10)
}

model Trip {
  id             String    @id @default(cuid())
  vehicleId      String
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId       String
  driver         Driver    @relation(fields: [driverId], references: [id])
  checkInTime    DateTime  @default(now())
  autoCheckoutAt DateTime?
  checkOutTime   DateTime?
  status         String    @default("active")
  paymentMethod  String?
  amount         Int
  passengers     Int?
  priceOptionId  String?
  priceOption    PassengerPrice? @relation(fields: [priceOptionId], references: [id], onDelete: SetNull)
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([driverId])
  @@index([vehicleId])
}
